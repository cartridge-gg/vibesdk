ARG SANDBOX_PLATFORM=linux/amd64
FROM --platform=${SANDBOX_PLATFORM} docker.io/cloudflare/sandbox:0.7.20 AS sandbox_runtime
FROM --platform=${SANDBOX_PLATFORM} docker.io/ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
ENV SANDBOX_VERSION=0.7.20
ENV PYTHON_POOL_MIN_SIZE=0
ENV JAVASCRIPT_POOL_MIN_SIZE=3
ENV TYPESCRIPT_POOL_MIN_SIZE=3

RUN apt-get update && \
        apt-get install -y --no-install-recommends \
        ca-certificates curl wget procps net-tools git unzip zip jq file inotify-tools \
        s3fs fuse3 squashfs-tools squashfuse fuse-overlayfs \
        libssl3 zlib1g libbz2-1.0 libreadline8t64 libsqlite3-0 libncursesw6 libtinfo6 \
        libxml2 libxmlsec1t64 libffi8 liblzma5 libtk8.6 && \
        update-ca-certificates && \
        sed -i 's/#user_allow_other/user_allow_other/' /etc/fuse.conf && \
        mkdir -p /workspace /workspace/container /workspace/data /container-server && \
        case "$(dpkg --print-architecture)" in \
            "amd64") ARCH="amd64" ;; \
            "arm64") ARCH="arm64" ;; \
            *) echo "Unsupported architecture: $(dpkg --print-architecture)"; exit 1 ;; \
        esac && \
        curl -L -k --output cloudflared "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${ARCH}" && \
        chmod +x cloudflared && \
        mv cloudflared /usr/local/bin/ && \
        git config --global user.email "vibesdk-bot@cloudflare.com" && \
        git config --global user.name "Cloudflare Vibesdk bot" && \
        rm -rf /var/lib/apt/lists/*

COPY --from=sandbox_runtime /container-server/sandbox /container-server/sandbox
COPY --from=sandbox_runtime /container-server/dist /container-server/dist
COPY --from=sandbox_runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=sandbox_runtime /usr/local/bin/bun /usr/local/bin/bun
COPY --from=sandbox_runtime /usr/local/lib/node_modules /usr/local/lib/node_modules

RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
        ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

# Create directory for error monitoring system
# Copy the process monitoring system
COPY container/ /workspace/container/

# Expose the ports you want to expose

# Install dependencies for the monitoring system
WORKDIR /workspace/container
RUN bun install && bun run build

# Make scripts executable
RUN chmod +x /workspace/container/cli-tools.ts

# Ensure bunx is available (should be included with bun)
RUN which bunx || ln -sf $(which bun) /usr/local/bin/bunx

# Install tsc via bunx
RUN bunx tsc --version

RUN case "$(dpkg --print-architecture)" in \
            "amd64") ARCH="amd64" ;; \
            "arm64") ARCH="arm64" ;; \
            *) echo "Unsupported architecture: $(dpkg --print-architecture)"; exit 1 ;; \
        esac && \
        curl -fsSL -o /tmp/dojo.tar.gz "https://github.com/dojoengine/dojo/releases/download/v1.8.0/dojo_v1.8.0_linux_${ARCH}.tar.gz" && \
        tar -xzf /tmp/dojo.tar.gz -C /usr/local/bin sozo && \
        curl -fsSL -o /tmp/katana.tar.gz "https://github.com/dojoengine/katana/releases/download/v1.7.1/katana_v1.7.1_linux_${ARCH}.tar.gz" && \
        tar -xzf /tmp/katana.tar.gz -C /usr/local/bin katana && \
        curl -fsSL -o /tmp/torii.tar.gz "https://github.com/dojoengine/torii/releases/download/v1.8.15/torii_v1.8.15_linux_${ARCH}.tar.gz" && \
        tar -xzf /tmp/torii.tar.gz -C /usr/local/bin torii && \
        chmod +x /usr/local/bin/sozo /usr/local/bin/katana /usr/local/bin/torii && \
        sozo --version && \
        katana --version && \
        torii --version && \
        rm -f /tmp/dojo.tar.gz /tmp/katana.tar.gz /tmp/torii.tar.gz

# Create symlinks for easier CLI usage
RUN ln -sf /workspace/container/cli-tools.ts /usr/local/bin/monitor-cli

# # Setup common templates packages cache
# WORKDIR /app/container/packages-cache
# ENV BUN_INSTALL_CACHE_DIR=/app/container/packages-cache
# RUN bun install

# Set proper permissions for data directory
RUN chmod 755 /workspace/data

# Set environment variable to indicate Docker container environment
ENV CONTAINER_ENV=docker
ENV VITE_LOGGER_TYPE=json 
# # Set environment variable to indicate Docker container environment
# ENV CONTAINER_ENV=docker

# # Reset workdir
WORKDIR /container-server

EXPOSE 3000 8001-8999

ENTRYPOINT ["/container-server/sandbox"]

# Keep the sandbox process alive; sessions run user commands on demand.
CMD ["sleep", "infinity"]
